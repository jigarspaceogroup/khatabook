// Khatabook Clone - Complete Database Schema
// Version: 1.0
// Date: April 6, 2026
// Database: PostgreSQL 15+ (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS (9 total)
// ============================================================================

enum TransactionType {
  GAVE // You gave (credit/udhar) - increases customer balance
  GOT // You got (debit/jama) - decreases customer balance
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

enum StockMovementType {
  IN // Stock received/purchased
  OUT // Stock sold/consumed
  ADJUSTMENT // Manual correction
}

enum ReminderType {
  WHATSAPP
  SMS
  EMAIL
}

enum ReminderStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  NETBANKING
  CHEQUE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
}

enum SyncStatus {
  PENDING
  SYNCED
  CONFLICT
  FAILED
}

// ============================================================================
// GROUP A: AUTHENTICATION & USER MANAGEMENT (2 tables)
// ============================================================================

model User {
  id                String    @id @default(uuid()) @db.Uuid
  phone_number      String    @unique @db.VarChar(15)
  phone_verified    Boolean   @default(false)
  name              String?   @db.VarChar(255)
  email             String?   @unique @db.VarChar(255)
  language_code     String    @default("en") @db.VarChar(10)
  profile_image_url String?   @db.Text
  biometric_enabled Boolean   @default(false)
  pin_hash          String?   @db.VarChar(255)
  last_login_at     DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @default(now()) @updatedAt
  deleted_at        DateTime?

  // Relationships
  khatabooks    Khatabook[]
  sessions      Session[]
  sync_metadata SyncMetadata[]
  audit_logs    AuditLog[]

  @@index([email])
  @@map("users")
}

model Session {
  id                 String    @id @default(uuid()) @db.Uuid
  user_id            String    @db.Uuid
  device_id          String    @db.VarChar(255)
  device_type        String    @db.VarChar(50)
  device_name        String?   @db.VarChar(255)
  refresh_token_hash String    @db.VarChar(255)
  ip_address         String?   @db.VarChar(45)
  user_agent         String?   @db.Text
  expires_at         DateTime
  last_activity_at   DateTime  @default(now())
  created_at         DateTime  @default(now())
  revoked_at         DateTime?

  // Relationships
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, device_id])
  @@index([refresh_token_hash])
  @@map("sessions")
}

// ============================================================================
// GROUP B: KHATABOOK MANAGEMENT (1 table)
// ============================================================================

model Khatabook {
  id            String    @id @default(uuid()) @db.Uuid
  user_id       String    @db.Uuid
  name          String    @db.VarChar(255)
  business_name String?   @db.VarChar(255)
  business_type String?   @db.VarChar(100)
  is_default    Boolean   @default(false)
  currency_code String    @default("INR") @db.VarChar(3)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @default(now()) @updatedAt
  deleted_at    DateTime?

  // Relationships
  user             User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  customers        Customer[]
  transactions     Transaction[]
  invoices         Invoice[]
  invoice_settings InvoiceSettings?
  inventory_items  InventoryItem[]
  reminder_logs    ReminderLog[]
  payments         Payment[]
  audit_logs       AuditLog[]

  @@index([user_id])
  @@index([user_id, is_default])
  @@map("khatabooks")
}

// ============================================================================
// GROUP C: PARTY & TRANSACTION MANAGEMENT (3 tables)
// ============================================================================

model Customer {
  id                  String    @id @default(uuid()) @db.Uuid
  khatabook_id        String    @db.Uuid
  name                String    @db.VarChar(255)
  phone_number        String?   @db.VarChar(15)
  email               String?   @db.VarChar(255)
  address             String?   @db.Text
  gstin               String?   @db.VarChar(15)
  opening_balance     Int       @default(0) // In paise
  current_balance     Int       @default(0) // In paise (+ = they owe you, - = you owe them)
  notes               String?   @db.Text
  last_transaction_at DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt
  deleted_at          DateTime?

  // Relationships
  khatabook     Khatabook     @relation(fields: [khatabook_id], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  invoices      Invoice[]
  reminder_logs ReminderLog[]
  payments      Payment[]

  @@index([khatabook_id])
  @@index([phone_number])
  @@index([current_balance])
  @@index([khatabook_id, current_balance(sort: Desc)])
  @@map("customers")
}

model Transaction {
  id               String          @id @default(uuid()) @db.Uuid
  khatabook_id     String          @db.Uuid
  customer_id      String          @db.Uuid
  type             TransactionType
  amount           Int // In paise (always positive)
  note             String?         @db.Text
  transaction_date DateTime
  payment_mode     String?         @db.VarChar(50)
  invoice_id       String?         @db.Uuid
  created_at       DateTime        @default(now())
  updated_at       DateTime        @default(now()) @updatedAt
  deleted_at       DateTime?

  // Relationships
  khatabook   Khatabook               @relation(fields: [khatabook_id], references: [id], onDelete: Cascade)
  customer    Customer                @relation(fields: [customer_id], references: [id], onDelete: Restrict)
  invoice     Invoice?                @relation(fields: [invoice_id], references: [id], onDelete: SetNull)
  attachments TransactionAttachment[]

  @@index([khatabook_id])
  @@index([customer_id])
  @@index([transaction_date])
  @@index([customer_id, transaction_date(sort: Desc)])
  @@index([khatabook_id, transaction_date(sort: Desc)])
  @@map("transactions")
}

model TransactionAttachment {
  id             String   @id @default(uuid()) @db.Uuid
  transaction_id String   @db.Uuid
  file_url       String   @db.Text
  file_type      String   @db.VarChar(50)
  file_size      Int?
  thumbnail_url  String?  @db.Text
  created_at     DateTime @default(now())

  // Relationships
  transaction Transaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)

  @@index([transaction_id])
  @@map("transaction_attachments")
}

// ============================================================================
// GROUP D: INVOICING (3 tables)
// ============================================================================

model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  khatabook_id   String        @db.Uuid
  customer_id    String        @db.Uuid
  invoice_number String        @db.VarChar(50)
  invoice_date   DateTime      @db.Date
  due_date       DateTime?     @db.Date
  status         InvoiceStatus @default(DRAFT)
  subtotal       Int // In paise
  tax_amount     Int           @default(0) // In paise
  total_amount   Int // In paise
  notes          String?       @db.Text
  is_gst_invoice Boolean       @default(false)
  pdf_url        String?       @db.Text
  created_at     DateTime      @default(now())
  updated_at     DateTime      @default(now()) @updatedAt
  deleted_at     DateTime?

  // Relationships
  khatabook    Khatabook     @relation(fields: [khatabook_id], references: [id], onDelete: Cascade)
  customer     Customer      @relation(fields: [customer_id], references: [id], onDelete: Restrict)
  items        InvoiceItem[]
  transactions Transaction[]
  payments     Payment[]

  @@unique([khatabook_id, invoice_number], map: "idx_invoices_number_unique")
  @@index([khatabook_id])
  @@index([customer_id])
  @@index([invoice_date])
  @@index([status])
  @@map("invoices")
}

model InvoiceItem {
  id                String   @id @default(uuid()) @db.Uuid
  invoice_id        String   @db.Uuid
  inventory_item_id String?  @db.Uuid
  item_name         String   @db.VarChar(255)
  description       String?  @db.Text
  quantity          Decimal  @default(1.00) @db.Decimal(10, 2)
  unit              String?  @db.VarChar(50)
  rate              Int // In paise
  tax_rate          Decimal  @default(0.00) @db.Decimal(5, 2)
  tax_amount        Int      @default(0) // In paise
  total             Int // In paise
  hsn_code          String?  @db.VarChar(20)
  sort_order        Int      @default(0)
  created_at        DateTime @default(now())

  // Relationships
  invoice        Invoice        @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  inventory_item InventoryItem? @relation(fields: [inventory_item_id], references: [id], onDelete: SetNull)

  @@index([invoice_id])
  @@index([inventory_item_id])
  @@map("invoice_items")
}

model InvoiceSettings {
  id                   String   @id @default(uuid()) @db.Uuid
  khatabook_id         String   @unique @db.Uuid
  business_name        String?  @db.VarChar(255)
  business_address     String?  @db.Text
  business_phone       String?  @db.VarChar(15)
  business_email       String?  @db.VarChar(255)
  gstin                String?  @db.VarChar(15)
  logo_url             String?  @db.Text
  invoice_prefix       String   @default("INV") @db.VarChar(20)
  next_invoice_number  Int      @default(1)
  terms_and_conditions String?  @db.Text
  bank_details         Json?
  created_at           DateTime @default(now())
  updated_at           DateTime @default(now()) @updatedAt

  // Relationships
  khatabook Khatabook @relation(fields: [khatabook_id], references: [id], onDelete: Cascade)

  @@map("invoice_settings")
}

// ============================================================================
// GROUP E: INVENTORY MANAGEMENT (2 tables - P2 Feature)
// ============================================================================

model InventoryItem {
  id              String    @id @default(uuid()) @db.Uuid
  khatabook_id    String    @db.Uuid
  item_name       String    @db.VarChar(255)
  description     String?   @db.Text
  sku             String?   @db.VarChar(100)
  barcode         String?   @db.VarChar(100)
  unit            String    @default("pcs") @db.VarChar(50)
  purchase_price  Int? // In paise
  selling_price   Int // In paise
  current_stock   Decimal   @default(0.00) @db.Decimal(10, 2)
  min_stock_level Decimal?  @db.Decimal(10, 2)
  hsn_code        String?   @db.VarChar(20)
  tax_rate        Decimal   @default(0.00) @db.Decimal(5, 2)
  image_url       String?   @db.Text
  created_at      DateTime  @default(now())
  updated_at      DateTime  @default(now()) @updatedAt
  deleted_at      DateTime?

  // Relationships
  khatabook     Khatabook     @relation(fields: [khatabook_id], references: [id], onDelete: Cascade)
  invoice_items InvoiceItem[]
  stock_logs    StockLog[]

  @@index([khatabook_id])
  @@index([sku])
  @@index([barcode])
  @@index([current_stock])
  @@map("inventory_items")
}

model StockLog {
  id                String            @id @default(uuid()) @db.Uuid
  inventory_item_id String            @db.Uuid
  type              StockMovementType
  quantity          Decimal           @db.Decimal(10, 2)
  balance_after     Decimal           @db.Decimal(10, 2)
  reason            String?           @db.VarChar(255)
  reference_id      String?           @db.Uuid
  reference_type    String?           @db.VarChar(50)
  notes             String?           @db.Text
  created_at        DateTime          @default(now())

  // Relationships
  inventory_item InventoryItem @relation(fields: [inventory_item_id], references: [id], onDelete: Cascade)

  @@index([inventory_item_id])
  @@index([created_at])
  @@map("stock_logs")
}

// ============================================================================
// GROUP F: NOTIFICATIONS & REMINDERS (1 table)
// ============================================================================

model ReminderLog {
  id                  String         @id @default(uuid()) @db.Uuid
  khatabook_id        String         @db.Uuid
  customer_id         String         @db.Uuid
  type                ReminderType
  message             String         @db.Text
  status              ReminderStatus
  balance_at_send     Int // In paise
  provider_message_id String?        @db.VarChar(255)
  error_message       String?        @db.Text
  sent_at             DateTime       @default(now())
  delivered_at        DateTime?

  // Relationships
  khatabook Khatabook @relation(fields: [khatabook_id], references: [id], onDelete: Cascade)
  customer  Customer  @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([customer_id])
  @@index([sent_at])
  @@index([status])
  @@map("reminder_logs")
}

// ============================================================================
// GROUP G: PAYMENTS (1 table - P1 Feature)
// ============================================================================

model Payment {
  id                 String        @id @default(uuid()) @db.Uuid
  khatabook_id       String        @db.Uuid
  customer_id        String        @db.Uuid
  invoice_id         String?       @db.Uuid
  amount             Int // In paise
  gateway            String        @db.VarChar(50)
  payment_method     String?       @db.VarChar(50)
  gateway_payment_id String?       @unique @db.VarChar(255)
  gateway_order_id   String?       @db.VarChar(255)
  status             PaymentStatus
  payment_link       String?       @db.Text
  paid_at            DateTime?
  failed_reason      String?       @db.Text
  metadata           Json?
  created_at         DateTime      @default(now())
  updated_at         DateTime      @default(now()) @updatedAt

  // Relationships
  khatabook Khatabook @relation(fields: [khatabook_id], references: [id], onDelete: Cascade)
  customer  Customer  @relation(fields: [customer_id], references: [id], onDelete: Restrict)
  invoice   Invoice?  @relation(fields: [invoice_id], references: [id], onDelete: SetNull)

  @@index([customer_id])
  @@index([invoice_id])
  @@index([status])
  @@map("payments")
}

// ============================================================================
// GROUP H: SYSTEM TABLES (2 tables)
// ============================================================================

model AuditLog {
  id             String      @id @default(uuid()) @db.Uuid
  user_id        String      @db.Uuid
  khatabook_id   String?     @db.Uuid
  entity_type    String      @db.VarChar(100)
  entity_id      String      @db.Uuid
  action         AuditAction
  changed_fields Json?
  old_values     Json?
  new_values     Json?
  ip_address     String?     @db.VarChar(45)
  user_agent     String?     @db.Text
  device_id      String?     @db.VarChar(255)
  created_at     DateTime    @default(now())

  // Relationships
  user      User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  khatabook Khatabook? @relation(fields: [khatabook_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([entity_type, entity_id])
  @@index([khatabook_id])
  @@index([created_at])
  @@index([action])
  @@map("audit_logs")
}

model SyncMetadata {
  id               String      @id @default(uuid()) @db.Uuid
  user_id          String      @db.Uuid
  device_id        String      @db.VarChar(255)
  entity_type      String      @db.VarChar(100)
  entity_id        String      @db.Uuid
  operation        AuditAction
  local_timestamp  DateTime
  server_timestamp DateTime?
  sync_status      SyncStatus  @default(PENDING)
  version          Int         @default(1)
  conflict_data    Json?
  retry_count      Int         @default(0)
  error_message    String?     @db.Text
  created_at       DateTime    @default(now())
  synced_at        DateTime?

  // Relationships
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([device_id, entity_type, entity_id, local_timestamp])
  @@index([user_id, device_id])
  @@index([entity_type, entity_id])
  @@index([sync_status])
  @@index([local_timestamp])
  @@map("sync_metadata")
}
